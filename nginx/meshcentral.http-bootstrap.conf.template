server {
    listen 80;
    server_name ${MESH_FQDN};

    location = /nginx-healthz {
        access_log off;
        return 200 "ok\n";
    }

    location /.well-known/acme-challenge/ {
        root ${CERTBOT_WEBROOT};
    }

    location / {
        default_type text/plain;
        return 503 "MeshCentral is bootstrapping HTTPS.\n";
    }
}
